---
// Frontier appendix: the candidate formalisation of option space.
//
// This document is the keystone formalisation — option space as the set of
// reachable configurations under a bounded exergy budget, with local Δω as the
// operational counterpart to the non-computable global measure. Its
// conclusions live on the spine as `option-space-measurability` (open) and
// `option-space-as-chess-moves`; the full worked formalisation is kept here,
// verbatim, as live frontier material. It is not a "draft" — there is no
// backstage — it is the open edge of the work, shown in full.

import { marked } from 'marked';
import { VERSION, BUILD } from '../../lib/version';

export const prerender = true;

const raw = (import.meta.glob('../../content/frontier/option-space-formalisation.md', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>);
const content = Object.values(raw)[0] ?? '';

const titleMatch = content.match(/^#\s+(.+)$/m);
const title = titleMatch ? titleMatch[1].trim() : 'Option Space — A Candidate Formalisation';
const body = content.replace(/^#\s+.+$/m, '').trim();
const html = marked.parse(body, { async: false }) as string;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Research Frontier — Configuration Economics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Sora:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav class="top-nav">
      <a href="/" class="nav-home">Configuration Economics</a>
      <div class="nav-right">
        <a href="/research-frontier" class="nav-link">Frontier</a>
        <a href="/explore" class="nav-link">Propositions</a>
        <a href="/essay" class="nav-link">Essay</a>
        <span class="nav-version">{VERSION}</span>
        <span class="nav-build">build {BUILD}</span>
      </div>
    </nav>

    <main>
      <header class="page-header">
        <div class="header-meta">
          <span class="status-badge">FRONTIER · FORMALISATION</span>
        </div>
        <h1>{title}</h1>
      </header>

      <aside class="frontier-banner">
        <p><strong>This is the open edge of the work, shown in full.</strong> The conclusions of this formalisation live on the spine as <a href="/explore#option-space-measurability">option-space-measurability</a> (status: open) and <a href="/explore#option-space-as-chess-moves">option-space-as-chess-moves</a>. The complete worked argument is kept here because a Living Epistemic Work publishes its frontier rather than hiding it — see <a href="/practice">/practice</a>.</p>
      </aside>

      <article class="frontier-content" set:html={html} />

      <footer class="page-footer">
        <p>Return to the <a href="/research-frontier">research frontier</a>, or see the <a href="/explore">propositions</a> these conclusions became.</p>
      </footer>
    </main>

    <style is:global>
      :root {
        --void: #0a0a0c;
        --text-primary: #e8e8f0;
        --text-secondary: #a0a0b8;
        --text-muted: #606080;
        --accent: #4a9eff;
        --status-frontier: #a66bd8;
        --font-display: 'Cormorant Garamond', serif;
        --font-body: 'Sora', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: var(--font-body); background: var(--void); color: var(--text-primary); min-height: 100vh; line-height: 1.7; }
      .top-nav { position: fixed; top: 0; left: 0; right: 0; height: 56px; background: rgba(10,10,12,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; gap: 2rem; padding: 0 2rem; z-index: 100; }
      .nav-home { font-family: var(--font-display); font-size: 1.125rem; color: var(--text-primary); text-decoration: none; }
      .nav-link { font-size: 0.875rem; color: var(--text-secondary); text-decoration: none; }
      .nav-link:hover { color: var(--accent); }
      .nav-right { display: flex; align-items: center; gap: 1rem; margin-left: auto; flex-wrap: wrap; }
      .nav-version { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); }
      .nav-build { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); opacity: 0.7; }
      main { max-width: 820px; margin: 0 auto; padding: 100px 2rem 6rem; }
      .page-header { margin-bottom: 2rem; }
      .header-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; }
      .status-badge { font-family: var(--font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.12em; padding: 0.25rem 0.55rem; border-radius: 3px; color: var(--status-frontier); border: 1px solid rgba(166,107,216,0.4); background: rgba(166,107,216,0.08); }
      .page-header h1 { font-family: var(--font-display); font-size: 2.25rem; font-weight: 400; line-height: 1.25; }
      .frontier-banner { margin-bottom: 3rem; padding: 1rem 1.25rem; background: rgba(166,107,216,0.05); border: 1px solid rgba(166,107,216,0.2); border-left: 2px solid var(--status-frontier); border-radius: 4px; }
      .frontier-banner p { color: var(--text-secondary); font-size: 0.875rem; line-height: 1.65; }
      .frontier-banner strong { color: var(--text-primary); font-weight: 500; }
      .frontier-banner a { color: var(--accent); text-decoration: none; }
      .frontier-banner a:hover { text-decoration: underline; }
      .frontier-content { color: var(--text-secondary); font-size: 0.9375rem; line-height: 1.75; }
      .frontier-content h1, .frontier-content h2, .frontier-content h3, .frontier-content h4 { font-family: var(--font-display); font-weight: 500; color: var(--text-primary); line-height: 1.3; }
      .frontier-content h2 { font-size: 1.625rem; margin: 3rem 0 1.25rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
      .frontier-content h3 { font-size: 1.25rem; margin: 2.25rem 0 1rem; }
      .frontier-content h4 { font-size: 1.0625rem; margin: 1.75rem 0 0.75rem; }
      .frontier-content p { margin-bottom: 1.125rem; }
      .frontier-content em { color: var(--text-primary); font-style: italic; }
      .frontier-content strong { color: var(--text-primary); font-weight: 500; }
      .frontier-content a { color: var(--accent); text-decoration: none; }
      .frontier-content a:hover { text-decoration: underline; }
      .frontier-content ul, .frontier-content ol { margin: 0 0 1.25rem 1.5rem; padding-left: 0.5rem; }
      .frontier-content li { margin-bottom: 0.5rem; }
      .frontier-content blockquote { margin: 1.5rem 0; padding: 0.75rem 1.25rem; background: rgba(255,255,255,0.02); border-left: 2px solid var(--accent); color: var(--text-secondary); font-style: italic; }
      .frontier-content code { font-family: var(--font-mono); font-size: 0.8125rem; background: rgba(255,255,255,0.06); padding: 0.15em 0.4em; border-radius: 3px; color: var(--text-primary); }
      .frontier-content pre { margin: 1.5rem 0; padding: 1.25rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 4px; overflow-x: auto; font-size: 0.8125rem; line-height: 1.6; }
      .frontier-content pre code { background: transparent; padding: 0; font-size: inherit; color: var(--text-secondary); }
      .frontier-content hr { margin: 3rem 0; border: none; border-top: 1px solid rgba(255,255,255,0.08); }
      .frontier-content table { margin: 1.5rem 0; width: 100%; border-collapse: collapse; font-size: 0.875rem; }
      .frontier-content th, .frontier-content td { padding: 0.6rem 0.85rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.06); vertical-align: top; }
      .frontier-content th { font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); font-weight: 500; }
      .frontier-content td { color: var(--text-secondary); }
      .page-footer { margin-top: 5rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.06); color: var(--text-muted); font-size: 0.875rem; }
      .page-footer a { color: var(--accent); text-decoration: none; }
      @media (max-width: 600px) { main { padding: 80px 1.25rem 4rem; } .page-header h1 { font-size: 1.75rem; } .frontier-content h2 { font-size: 1.375rem; } }
    </style>
  </body>
</html>
