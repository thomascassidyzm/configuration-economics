        --font-body: 'Sora', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-body);
        background: var(--void);
        color: var(--text-primary);
        min-height: 100vh;
        line-height: 1.7;
      }

      .top-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 56px;
        background: rgba(10, 10, 12, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 0 2rem;
        z-index: 100;
      }

      .nav-home {
        font-family: var(--font-display);
        font-size: 1.125rem;
        color: var(--text-primary);
        text-decoration: none;
      }

      .nav-link {
        font-size: 0.875rem;
        color: var(--text-secondary);
        text-decoration: none;
      }

      .nav-link:hover { color: var(--accent); }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-left: auto;
      }

      .nav-version {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--accent);
      }

      .nav-build {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        opacity: 0.7;
      }

      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 100px 2rem 6rem;
      }

      /* Reserve room for the GuidePanel on desktop. */
      @media (min-width: 1101px) {
        main {
          margin-right: 460px;
        }
      }

      .page-header {
        margin-bottom: 3rem;
      }

      .page-header h1 {
        font-family: var(--font-display);
        font-size: 2.25rem;
        font-weight: 400;
        margin-bottom: 0.75rem;
      }

      .subtitle {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 0.5rem;
      }

      .note {
        color: var(--text-muted);
        font-size: 0.875rem;
      }

      .note a,
      .page-footer a,
      .intent a,
      .concession a,
      .response a,
      .differs a,
      .section-intro a {
        color: var(--accent);
        text-decoration: none;
      }

      .note a:hover,
      .page-footer a:hover,
      .intent a:hover,
      .response a:hover { text-decoration: underline; }

      .intent {
        margin-bottom: 3.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }

      .intent p {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.7;
        margin-bottom: 1rem;
      }

      .intent p:last-child { margin-bottom: 0; }

      .differs {
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(255,255,255,0.04);
      }

      .differs strong {
        color: var(--text-primary);
        font-weight: 500;
      }

      .objection {
        margin-bottom: 4.5rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }

      .objection:last-of-type {
        border-bottom: none;
        margin-bottom: 3rem;
      }

      .obj-title {
        font-family: var(--font-display);
        font-size: 1.75rem;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
      }

      .obj-num {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--accent);
        font-weight: 400;
      }

      .steelman {
        margin: 0 0 2rem;
        padding: 1.25rem 1.5rem;
        border-left: 3px solid var(--steelman-red);
        background: rgba(201, 112, 112, 0.05);
        border-radius: 0 4px 4px 0;
      }

      .steelman p {
        color: var(--text-primary);
        font-style: italic;
        font-size: 0.9375rem;
        line-height: 1.7;
      }

      .response {
        margin-bottom: 1.75rem;
      }

      .response p,
      .response ul {
        color: var(--text-primary);
        font-size: 0.9375rem;
        line-height: 1.75;
        margin-bottom: 1rem;
      }

      .response ul {
        padding-left: 1.5rem;
        list-style: disc;
      }

      .response li {
        margin-bottom: 0.5rem;
      }

      .response strong {
        color: var(--text-primary);
        font-weight: 500;
      }

      .hostile-critic {
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 1px dashed rgba(255,255,255,0.08);
      }

      .prop-quote {
        margin: 1rem 0 1.25rem 0.5rem;
        padding: 0.75rem 1.25rem;
        border-left: 2px solid var(--accent);
        background: rgba(74, 158, 255, 0.04);
        border-radius: 0 4px 4px 0;
      }

      .prop-quote p {
        color: var(--text-primary);
        font-style: italic;
        font-size: 0.9375rem;
        line-height: 1.65;
      }

      .concession {
        padding: 1rem 1.25rem;
        background: rgba(74, 158, 255, 0.04);
        border: 1px solid rgba(74, 158, 255, 0.15);
        border-left: 2px solid var(--accent);
        border-radius: 4px;
      }

      .concession-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
      }

      .concession p {
        color: var(--text-primary);
        font-size: 0.9375rem;
        line-height: 1.7;
      }

      .response code,
      .concession code,
      .resolved-entry code,
      .open-entry code,
      .intent code,
      .prop-quote code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        color: var(--accent);
        background: rgba(74, 158, 255, 0.06);
        padding: 0.05em 0.35em;
        border-radius: 3px;
      }

      .resolved-section,
      .open-section {
        margin-top: 2rem;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }

      .resolved-section h2,
      .open-section h2 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: 1rem;
      }

      .resolved-section h3 {
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--text-secondary);
        margin: 2.5rem 0 1.5rem;
      }

      .section-intro {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.7;
        margin-bottom: 2rem;
      }

      .resolved-entry {
        padding-left: 1.25rem;
        border-left: 2px solid rgba(255,255,255,0.08);
        margin-bottom: 1.25rem;
      }

      .resolved-entry p {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.7;
      }

      .resolved-entry.partial p {
        color: var(--text-secondary);
        opacity: 0.92;
      }

      .resolved-entry strong {
        color: var(--text-primary);
        font-weight: 500;
      }

      .open-entry {
        position: relative;
        padding: 1.25rem 1.5rem;
        background: rgba(166, 107, 216, 0.04);
        border: 1px solid rgba(166, 107, 216, 0.15);
        border-left: 2px solid var(--open-purple);
        border-radius: 4px;
        margin-bottom: 1.5rem;
      }

      .open-entry:last-child {
        margin-bottom: 0;
      }

      .open-label {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--open-purple);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
      }

      .open-entry h3 {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
      }

      .open-entry p {
        color: var(--text-primary);
        font-size: 0.9375rem;
        line-height: 1.7;
      }

      .page-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        color: var(--text-muted);
        font-size: 0.875rem;
      }

      .page-footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 600px) {
        main {
          padding: 80px 1.25rem 4rem;
        }

        .page-header h1 {
          font-size: 1.75rem;
        }

        .obj-title {
          font-size: 1.375rem;
        }

        .steelman,
        .concession,
        .open-entry {
          padding: 1rem;
        }

        .resolved-entry {
          padding-left: 1rem;
        }
      }
    </style>
  </body>
</html>
