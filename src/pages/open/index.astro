---
// /open — the work in the open. Index of live working material: applications,
// evaluations, the method, the register. Published as it happens.
import { VERSION, BUILD } from '../../lib/version';

const META: { slug: string; title: string; kind: string; blurb: string }[] = [
  { slug: 'NOTES-six-hat-method', title: 'The Six-Hat evaluation method', kind: 'Method',
    blurb: 'How proposals and artefacts are conceived and tested — the de Bono sequence run by an agent swarm, the fitness function, and the two seats (Red gut, final Blue verdict) kept human. The verdict is shown working, not handed down.' },
  { slug: 'NOTES-dna-economy-ogwen', title: 'The Ogwen DNA-economy cell', kind: 'Application',
    blurb: 'The lens pointed at one bounded sphere (Bethesda, Gwynedd): what is frozen, what is reachable, the sequenced loops that upregulate each turn, and the walls flagged in red.' },
  { slug: 'NOTES-ogwen-six-hats', title: 'The Ogwen six-hat run', kind: 'Evaluation',
    blurb: 'The first full Six-Thinking-Hats evaluation, published in full: White corrects, Yellow makes the case, Black finds the fracture, Green leaps. The two human seats left open.' },
  { slug: 'NOTES-ssi-currency-surface', title: 'SSi as the local-currency surface', kind: 'Proposal',
    blurb: 'Could SaySomethingin become the delivery + ledger + legitimacy surface for a local credit/currency — funding the language-preservation Δω the market won’t price? The proposal, written as input to its evaluation.' },
  { slug: 'NOTES-ssi-six-hats', title: 'The SSi six-hat run — a strong failure', kind: 'Evaluation',
    blurb: 'The second run, and the first to come back decisively critical — of the author’s own company. Published unedited, because a Living Epistemic Work cannot cherry-pick. A strong failure: certain doors closed, for now. Now we’re learning.' },
  { slug: 'NOTES-uk-legal-saudi-football', title: 'A UK legal company and the Saudi football money', kind: 'Proposal',
    blurb: 'A deliberately hard, ethically loaded scenario: can a UK law firm benefit significantly from the Saudi football capital on CE principles — greater life to all, less to none — or does every role reduce to sportswashing-enablement? The proposal, written as input to its evaluation.' },
  { slug: 'NOTES-saudi-legal-six-hats', title: 'The Saudi-legal six-hat run', kind: 'Evaluation',
    blurb: 'The method in the hardest domain yet — and its best work. It refused both the feel-good yes and the reflexive no: a clean positive-sum configuration exists, but cleanliness and scale are inversely correlated. The honest answer points at the exit, not the entrance.' },
  { slug: 'NOTES-autonomous-fleet-frozen-cars', title: 'Autonomous fleets and the frozen value in cars', kind: 'Proposal',
    blurb: 'The worked application of held-value-not-reachable: the 95%-idle private car is the textbook frozen asset; a shared autonomous fleet is the thaw. A practical, technically-ready test of the canon against reality.' },
  { slug: 'NOTES-autonomous-fleet-six-hats', title: 'The autonomous-fleet six-hat run', kind: 'Evaluation',
    blurb: 'The canon stress-tested. The frozen value is real — but the thaw and the re-freeze are the same motion: on the default configuration it re-freezes behind a private toll-gate. A greater-life-to-all version exists, won or lost at the per-city operating permit, racing a closing clock.' },
  { slug: 'NOTES-explanation-layer', title: 'The explanation layer', kind: 'Direction',
    blurb: 'The stake-in-the-ground for the constructive arm: frozen value vs reachable value, the altitude move, and what a generative explanation layer would be.' },
  { slug: 'BACKLOG', title: 'Things to have a pop at', kind: 'Register',
    blurb: 'The living list: spheres to run the lens on, artefacts to conceive, intellectual lines to close, forming nodes to grow.' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Open — Configuration Economics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Sora:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
    <style is:global>
      :root { --void:#0a0a0c; --text-primary:#e8e8f0; --text-secondary:#a0a0b8; --text-muted:#606080; --accent:#4a9eff; --status-open:#3fb8c4; --font-display:'Cormorant Garamond',serif; --font-body:'Sora',sans-serif; --font-mono:'JetBrains Mono',monospace; }
      * { margin:0; padding:0; box-sizing:border-box; }
      body { font-family:var(--font-body); background:var(--void); color:var(--text-primary); min-height:100vh; line-height:1.7; }
      .top-nav { position:fixed; top:0; left:0; right:0; height:56px; background:rgba(10,10,12,0.95); backdrop-filter:blur(12px); border-bottom:1px solid rgba(255,255,255,0.06); display:flex; align-items:center; gap:2rem; padding:0 2rem; z-index:100; }
      .nav-home { font-family:var(--font-display); font-size:1.125rem; color:var(--text-primary); text-decoration:none; }
      .nav-link { font-size:0.875rem; color:var(--text-secondary); text-decoration:none; }
      .nav-link:hover { color:var(--accent); }
      .nav-right { display:flex; align-items:center; gap:1rem; margin-left:auto; flex-wrap:wrap; }
      .nav-version { font-family:var(--font-mono); font-size:0.75rem; color:var(--accent); }
      .nav-build { font-family:var(--font-mono); font-size:0.75rem; color:var(--text-muted); opacity:0.7; }
      main { max-width:820px; margin:0 auto; padding:100px 2rem 6rem; }
      h1 { font-family:var(--font-display); font-weight:500; font-size:2.6rem; margin:0 0 0.5rem; }
      .lede { color:var(--text-secondary); border-left:2px solid rgba(63,184,196,0.4); padding-left:1.2rem; margin:0 0 3rem; }
      .lede strong { color:var(--text-primary); font-weight:400; }
      .doc { display:block; text-decoration:none; border:1px solid rgba(255,255,255,0.08); border-radius:6px; padding:1.25rem 1.4rem; margin-bottom:1rem; transition:border-color 0.15s,background 0.15s; }
      .doc:hover { border-color:rgba(63,184,196,0.4); background:rgba(63,184,196,0.03); }
      .doc-kind { font-family:var(--font-mono); font-size:0.62rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--status-open); }
      .doc-title { font-family:var(--font-display); font-size:1.4rem; color:var(--text-primary); margin:0.2rem 0 0.4rem; }
      .doc-blurb { color:var(--text-secondary); font-size:0.9rem; margin:0; }
    </style>
  </head>
  <body>
    <nav class="top-nav">
      <a href="/" class="nav-home">Configuration Economics</a>
      <div class="nav-right">
        <a href="/explore" class="nav-link">Propositions</a>
        <a href="/motion" class="nav-link">Motion</a>
        <span class="nav-version">{VERSION}</span>
        <span class="nav-build">build {BUILD}</span>
      </div>
    </nav>
    <main>
      <h1>Open</h1>
      <p class="lede">The work in the open. <strong>Applications, evaluations, the method, and the register — published as they happen, not after they settle.</strong> A Living Epistemic Work keeps no backstage: the propositions climb in public on <a href="/motion" style="color:var(--accent)">/motion</a>, and the working that produces them lives here, uncertainty on its face.</p>
      {META.map(d => (
        <a class="doc" href={`/open/${d.slug}`}>
          <span class="doc-kind">{d.kind}</span>
          <div class="doc-title">{d.title}</div>
          <p class="doc-blurb">{d.blurb}</p>
        </a>
      ))}
    </main>
  </body>
</html>
