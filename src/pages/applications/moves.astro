<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Moves — Configuration Economics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
