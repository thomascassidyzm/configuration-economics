        font-size: 1rem;
        line-height: 1.6;
      }

      .block-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
      }

      .steelman {
        margin: 0 0 1.5rem;
        padding: 1.25rem 1.5rem;
        border-left: 3px solid var(--steelman-red);
        background: rgba(201, 112, 112, 0.05);
