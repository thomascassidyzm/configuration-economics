      .attack-cta:hover {
        background: rgba(230, 165, 69, 0.1);
        border-color: var(--amber);
        color: #fff;
      }

      /* Bring your own */
      .byo {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
      }

      .byo h2 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 500;
        margin-bottom: 1rem;
      }

      .byo p {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.75;
        margin-bottom: 1rem;
      }

      .byo-note { color: var(--text-muted); font-size: 0.875rem; }

      .inline-attack {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--amber);
        border: 1px solid rgba(230, 165, 69, 0.3);
        border-radius: 3px;
        padding: 0.05em 0.4em;
        white-space: nowrap;
      }

      .response code, .concession code, .blast-radius code, .intent code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        color: var(--accent);
        background: rgba(74, 158, 255, 0.06);
        padding: 0.05em 0.35em;
        border-radius: 3px;
      }

      .page-footer {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        color: var(--text-muted);
        font-size: 0.875rem;
      }

      @media (max-width: 600px) {
        main { padding: 80px 1.25rem 4rem; }
        .page-header h1 { font-size: 1.75rem; }
        .case-head h2 { font-size: 1.375rem; }
        .steelman, .concession, .premise-under-attack { padding: 1rem; }
      }
    </style>

    <script>
      // Hand each worked-example CTA to the GuidePanel's attackPremise entry
      // point, which puts Alexander into premise-defense mode bound to that
      // premise. We do not auto-send — the reader presses send (or edits to
      // their own attack), so no billed call fires on click.
      document.querySelectorAll<HTMLButtonElement>('.attack-cta').forEach(btn => {
        btn.addEventListener('click', () => {
          const w = window as any;
          if (typeof w.attackPremise === 'function') {
            w.attackPremise(
              btn.dataset.prop,
              btn.dataset.premise,
              btn.dataset.propTitle,
              btn.dataset.status
            );
          }
        });
      });
    </script>
  </body>
</html>
