---
// Dynamic route: render any markdown file from the repo's drafts/ directory
// as a web page. Drafts remain clearly labelled as drafts — this route
// publishes them for visibility, NOT for promotion to canonical content.

import { marked } from 'marked';
import { VERSION, BUILD } from '../../lib/version';

export const prerender = true;

interface DraftProps {
  title: string;
  html: string;
  filename: string;
  lastModified: string;
}

export async function getStaticPaths() {
  const draftModules = import.meta.glob('../../../drafts/*.md', {
    query: '?raw',
    import: 'default',
    eager: true,
  }) as Record<string, string>;

  return Object.entries(draftModules)
    .filter(([path]) => !path.endsWith('README.md'))
    .map(([path, content]) => {
      const filename = path.split('/').pop()!.replace(/\.md$/, '');

      // Pull title from first H1
      const titleMatch = content.match(/^#\s+(.+)$/m);
      const title = titleMatch ? titleMatch[1].trim() : filename;

      // Render markdown → HTML. Strip the H1 since the page header carries it.
      const bodyContent = content.replace(/^#\s+.+$/m, '').trim();
      const html = marked.parse(bodyContent, { async: false }) as string;

      // Last-modified — use a placeholder; build-time stat would require a different setup.
      // The draft prose itself usually carries a date in its status note.
      const lastModified = '';

      return {
        params: { slug: filename },
        props: { title, html, filename, lastModified } satisfies DraftProps,
      };
    });
}

const { title, html, filename } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Drafts — Configuration Economics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Sora:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav class="top-nav">
      <a href="/" class="nav-home">Configuration Economics</a>
      <div class="nav-right">
        <a href="/drafts" class="nav-link">All drafts</a>
        <a href="/research-frontier" class="nav-link">Frontier</a>
        <a href="/essay" class="nav-link">Essay</a>
        <span class="nav-version">{VERSION}</span>
        <span class="nav-build">build {BUILD}</span>
      </div>
    </nav>

    <main>
      <header class="page-header">
        <div class="header-meta">
          <span class="status-badge">DRAFT</span>
          <span class="filename">{filename}.md</span>
        </div>
        <h1>{title}</h1>
      </header>

      <aside class="draft-banner">
        <p><strong>This is work in progress.</strong> Drafts sit in the repository for review before promotion to canonical content. Voice, structure, and substance may shift. The reasoning is published openly because the work is a living epistemic project — see <a href="/practice">/practice</a>.</p>
      </aside>

      <article class="draft-content" set:html={html} />

      <footer class="page-footer">
        <p>Browse all <a href="/drafts">drafts</a>, or return to the <a href="/research-frontier">research frontier</a>.</p>
      </footer>
    </main>

    <style is:global>
      :root {
        --void: #0a0a0c;
        --depth-1: #12121a;
        --depth-2: #1a1a24;
        --text-primary: #e8e8f0;
        --text-secondary: #a0a0b8;
        --text-muted: #606080;
        --accent: #4a9eff;
        --status-draft: #e6a545;
        --font-display: 'Cormorant Garamond', serif;
        --font-body: 'Sora', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-body);
        background: var(--void);
        color: var(--text-primary);
        min-height: 100vh;
        line-height: 1.7;
      }

      .top-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 56px;
        background: rgba(10, 10, 12, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 0 2rem;
        z-index: 100;
      }

      .nav-home {
        font-family: var(--font-display);
        font-size: 1.125rem;
        color: var(--text-primary);
        text-decoration: none;
      }

      .nav-link {
        font-size: 0.875rem;
        color: var(--text-secondary);
        text-decoration: none;
      }

      .nav-link:hover { color: var(--accent); }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-left: auto;
        flex-wrap: wrap;
      }

      .nav-version {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--accent);
      }

      .nav-build {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        opacity: 0.7;
      }

      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 100px 2rem 6rem;
      }

      .page-header {
        margin-bottom: 2rem;
      }

      .header-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
      }

      .status-badge {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 0.25rem 0.55rem;
        border-radius: 3px;
        color: var(--status-draft);
        border: 1px solid rgba(230, 165, 69, 0.4);
        background: rgba(230, 165, 69, 0.08);
      }

      .filename {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .page-header h1 {
        font-family: var(--font-display);
        font-size: 2.25rem;
        font-weight: 400;
        line-height: 1.25;
      }

      .draft-banner {
        margin-bottom: 3rem;
        padding: 1rem 1.25rem;
        background: rgba(230, 165, 69, 0.05);
        border: 1px solid rgba(230, 165, 69, 0.2);
        border-left: 2px solid var(--status-draft);
        border-radius: 4px;
      }

      .draft-banner p {
        color: var(--text-secondary);
        font-size: 0.875rem;
        line-height: 1.65;
      }

      .draft-banner strong {
        color: var(--text-primary);
        font-weight: 500;
      }

      .draft-banner a {
        color: var(--accent);
        text-decoration: none;
      }

      .draft-banner a:hover {
        text-decoration: underline;
      }

      /* Markdown content rendering — applies to anything inside .draft-content */
      .draft-content {
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.75;
      }

      .draft-content h1,
      .draft-content h2,
      .draft-content h3,
      .draft-content h4 {
        font-family: var(--font-display);
        font-weight: 500;
        color: var(--text-primary);
        line-height: 1.3;
      }

      .draft-content h2 {
        font-size: 1.625rem;
        margin: 3rem 0 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }

      .draft-content h3 {
        font-size: 1.25rem;
        margin: 2.25rem 0 1rem;
      }

      .draft-content h4 {
        font-size: 1.0625rem;
        margin: 1.75rem 0 0.75rem;
      }

      .draft-content p {
        margin-bottom: 1.125rem;
      }

      .draft-content em {
        color: var(--text-primary);
        font-style: italic;
      }

      .draft-content strong {
        color: var(--text-primary);
        font-weight: 500;
      }

      .draft-content a {
        color: var(--accent);
        text-decoration: none;
      }

      .draft-content a:hover {
        text-decoration: underline;
      }

      .draft-content ul,
      .draft-content ol {
        margin: 0 0 1.25rem 1.5rem;
        padding-left: 0.5rem;
      }

      .draft-content li {
        margin-bottom: 0.5rem;
      }

      .draft-content li > ul,
      .draft-content li > ol {
        margin-top: 0.4rem;
        margin-bottom: 0.4rem;
      }

      .draft-content blockquote {
        margin: 1.5rem 0;
        padding: 0.75rem 1.25rem;
        background: rgba(255,255,255,0.02);
        border-left: 2px solid var(--accent);
        color: var(--text-secondary);
        font-style: italic;
        font-size: 0.9375rem;
      }

      .draft-content blockquote p {
        margin-bottom: 0.5rem;
      }

      .draft-content blockquote p:last-child {
        margin-bottom: 0;
      }

      .draft-content code {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        background: rgba(255,255,255,0.06);
        padding: 0.15em 0.4em;
        border-radius: 3px;
        color: var(--text-primary);
      }

      .draft-content pre {
        margin: 1.5rem 0;
        padding: 1.25rem;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 4px;
        overflow-x: auto;
        font-size: 0.8125rem;
        line-height: 1.6;
      }

      .draft-content pre code {
        background: transparent;
        padding: 0;
        font-size: inherit;
        color: var(--text-secondary);
      }

      .draft-content hr {
        margin: 3rem 0;
        border: none;
        border-top: 1px solid rgba(255,255,255,0.08);
      }

      .draft-content table {
        margin: 1.5rem 0;
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
      }

      .draft-content th,
      .draft-content td {
        padding: 0.6rem 0.85rem;
        text-align: left;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        vertical-align: top;
      }

      .draft-content th {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        font-weight: 500;
      }

      .draft-content td {
        color: var(--text-secondary);
      }

      .page-footer {
        margin-top: 5rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        color: var(--text-muted);
        font-size: 0.875rem;
      }

      .page-footer a {
        color: var(--accent);
        text-decoration: none;
      }

      .page-footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 600px) {
        main {
          padding: 80px 1.25rem 4rem;
        }

        .page-header h1 {
          font-size: 1.75rem;
        }

        .draft-content h2 {
          font-size: 1.375rem;
        }

        .draft-content h3 {
          font-size: 1.125rem;
        }

        .draft-content table {
          font-size: 0.8125rem;
        }

        .draft-content th,
        .draft-content td {
          padding: 0.5rem 0.6rem;
        }
      }
    </style>
  </body>
</html>
