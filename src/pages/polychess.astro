        font-size: 1.6rem;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: 1.25rem;
      }
      .infinite p {
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.75;
        margin-bottom: 1.1rem;
        max-width: 64ch;
      }
      .infinite em { color: var(--text-primary); font-style: italic; }
