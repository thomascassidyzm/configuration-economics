      .log-scores { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); margin-left: auto; }
      .log-closed { font-family: var(--font-mono); font-size: 0.72rem; color: var(--danger); flex-basis: 100%; }

      /* ---------- reflection ---------- */
      .reflection {
        background: var(--depth-1);
        border: 1px solid rgba(74,158,255,0.2);
