      .verdict-preserving .card-verdict { color: var(--verdict-preserving); }
      .verdict-expanding .card-verdict { color: var(--verdict-expanding); }
      .verdict-ambiguous .card-verdict { color: var(--verdict-ambiguous); }
      .card-blurb { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.45; }
