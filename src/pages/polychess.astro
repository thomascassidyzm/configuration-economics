      .mini-up { color: var(--cell-lit); }
      .mini-down { color: var(--verdict-degrading); }
      .mini-flat { color: var(--verdict-ambiguous); }

      /* ---------- move log ---------- */
      .log-section { margin-bottom: 3rem; }
      .log-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; margin-bottom: 1rem; }
      .log { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
      .log-empty { color: var(--text-muted); font-size: 0.875rem; font-style: italic; }
      .log-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        font-size: 0.82rem;
        padding: 0.5rem 0.75rem;
        border-radius: 5px;
        background: var(--depth-1);
        border-left: 2px solid var(--verdict-ambiguous);
      }
      .log-item.verdict-degrading { border-left-color: var(--verdict-degrading); }
      .log-item.verdict-preserving { border-left-color: var(--verdict-preserving); }
      .log-item.verdict-expanding { border-left-color: var(--verdict-expanding); }
      .log-item.verdict-ambiguous { border-left-color: var(--verdict-ambiguous); }
      .log-turn { font-family: var(--font-mono); color: var(--text-muted); width: 1.5rem; }
      .log-name { color: var(--text-primary); font-weight: 500; min-width: 10rem; }
