---
// Polychess — a bridge to the infinite game, not a game to win.
//
// A self-contained interactive toy. Four boards, each a grid of cells standing
// for the reachable set (option space) of one observer-class. Move-cards drawn
// from /applications/moves apply a per-board Δω: they light or extinguish cells.
// One number stays visible — the finite player's scoreboard, the seductive
// single-board GDP-like score that tempts you to "win" one board. The board
// never congratulates you for it and never declares a winner.
//
// There is no winning here, only continuation or foreclosure. The ONLY outcome
// that means anything is the END of the play: any board's reachable set
// collapsing to zero. When it happens, the reflection names the realization the
// whole page exists to deliver — you cannot win across all the boards, and the
// instinct to try is what ends the game. The game worth playing (Carse's
// infinite game) has no win; its only rule is to make no move that ends the
// play.
//
// Pure Astro + inline vanilla JS + inline CSS — no framework deps, no API, no
// Guide panel. A deliberately legible toy model of a deliberately illegible
// reality (legibility-truth-tradeoff). It makes the structure felt; it does not
// simulate or predict. Cell-counts are illustrative, not measurements.

import { VERSION, BUILD } from '../lib/version';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Polychess — Configuration Economics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Sora:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav class="top-nav">
      <a href="/" class="nav-home">Configuration Economics</a>
      <div class="nav-right">
        <a href="/overview" class="nav-link">Overview</a>
        <a href="/essay" class="nav-link">Essay</a>
        <a href="/explore" class="nav-link">Explore</a>
        <a href="/applications/moves" class="nav-link">Moves</a>
        <span class="nav-version">{VERSION}</span>
        <span class="nav-build">build {BUILD}</span>
      </div>
    </nav>

    <main>
      <header class="page-header">
        <h1>Polychess</h1>
        <p class="subtitle">A bridge to a different kind of game.</p>
        <p class="note">
          This is not a game to win. It is a short crossing to a realization.
          Standard economics keeps score on one board, and the moves that win
          there are <em>taking</em> moves on boards nobody is counting. Make a
          few. Watch option space open and close. There is no high score to
          chase here — only the one thing that ends the play, and what you learn
          when it does.
        </p>
      </header>

      <!-- ===== THE FINITE PLAYER'S SCOREBOARD ===== -->
      <!-- One number only. It is here to be resisted, not pursued. -->
      <section class="scores" aria-label="The finite player's scoreboard">
        <div class="score-card score-board1">
          <span class="score-label">The finite player's scoreboard · Board 1</span>
          <span class="score-value" id="board1-score">0</span>
          <span class="score-cap">
            the single GDP-like number, the score of <em>one</em> board.
            It only ever rises. Pursuing it is what ends the play.
          </span>
        </div>
      </section>

      <p class="turn-line">
        <span class="turn-label">Move</span>
        <span id="turn-count">0</span>
        <span class="turn-sep">·</span>
        <span id="poly-readout" class="poly-readout">all four boards open · 100 of 100 cells reachable</span>
        <span class="turn-sep">·</span>
        <span id="game-state" class="game-state state-open">the play continues</span>
      </p>

      <!-- ===== BOARDS ===== -->
      <section class="boards" id="boards" aria-label="Four boards, one per observer-class">
        <!-- boards injected by script -->
      </section>

      <!-- ===== DELTA PREVIEW ===== -->
      <div class="preview" id="preview" hidden>
        <span class="preview-label">If you play this move</span>
        <div class="preview-rows" id="preview-rows"></div>
        <span class="preview-note">directional only — per option-space-as-chess-moves, Δω is a sign, not a magnitude</span>
      </div>

      <!-- ===== DECK ===== -->
      <section class="deck-section" aria-label="The move deck">
        <div class="deck-head">
          <h2 class="deck-title">The deck</h2>
          <button id="reset-btn" class="reset-btn" type="button">Reset</button>
        </div>
        <p class="deck-hint">
          Hover a card to preview its Δω on each board — directional only, a
          sign and not a magnitude. Click to play it. Every card is a real
          configuration-change drawn from
          <a href="/applications/moves">the worked moves</a>, plus a few obvious
          generative ones. Notice which cards lift the scoreboard, and what they
          take to do it.
        </p>
        <div class="deck" id="deck">
          <!-- cards injected by script -->
        </div>
      </section>

      <!-- ===== MOVE LOG ===== -->
      <section class="log-section" aria-label="Move log">
        <h2 class="log-title">Move log</h2>
        <ol class="log" id="log">
          <li class="log-empty">No moves yet. The board starts fully open.</li>
        </ol>
      </section>

      <!-- ===== FORECLOSURE REFLECTION (the pivot) ===== -->
      <!-- Fires only when a board collapses. Names the realization the whole
           page exists to deliver. -->
      <section class="reflection" id="reflection" hidden>
        <h2 class="reflection-title" id="reflection-title">The play has ended</h2>
        <div class="reflection-body" id="reflection-body"></div>
      </section>

      <!-- ===== HONEST DISCLAIMER ===== -->
      <section class="disclaimer">
        <h2 class="disclaimer-title">An honest note on the toy</h2>
        <p>
          This is a deliberately <em>legible</em> toy model of a deliberately
          <em>illegible</em> reality. Its whole job is to make a structure
          <em>felt</em> — that one physical action registers as a move on several
          boards at once, scored differently on each, with king-pieces you
          didn't know you had. It does not simulate, measure, or predict.
        </p>
        <p>
          The cell-counts are illustrative, not measurements. Global option space
          is not computable — that is precisely why the framework evaluates
          <em>moves</em> locally and directionally rather than scoring
          <em>states</em> globally (<a href="/explore#option-space-measurability">option-space-measurability</a>).
          Crushing real biosphere dynamics into a 5×5 grid is exactly the
          legibility-for-truth trade the framework warns about
          (<a href="/explore#legibility-truth-tradeoff">legibility-truth-tradeoff</a>):
          the grid is legible and therefore lossy. Hold the feeling; discard the
          numbers.
        </p>
        <p class="disclaimer-foot">
          The real apparatus is the directional rule on R_living, worked on six
          real cases with their evidence and their ambiguities, at
          <a href="/applications/moves">/applications/moves</a>. This page is the
          four-resolution teaching device for that rule, made playable.
        </p>
      </section>

      <!-- ===== THE INFINITE GAME (the destination of the bridge) ===== -->
      <section class="infinite">
        <h2 class="infinite-title">The game on the other side of the bridge</h2>
        <p>
          James Carse drew the distinction this page is built on. A
          <em>finite</em> game is played to win: it has an agreed end, winners
          and losers, and it stops when someone wins. An <em>infinite</em> game
          is played to keep the play going: it has no end-state to reach and no
          score to top, and its players act to bring more players in and keep the
          game alive.
        </p>
        <p>
          Chess is finite. The scoreboard above is finite. The framework's
          objective is not.
        </p>
        <blockquote class="infinite-quote">
          “The point isn't to win it or finish it, but to keep it going and bring
          others in.”
        </blockquote>
        <p>
          That is the whole crossing. The boards were never a puzzle to solve or
          a score to maximise — they were a way to feel, in a few moves, that
          the instinct to <em>win</em> a board is exactly the instinct that
          empties another. The viable objective is the infinite game's only
          rule, stated in the framework's own terms: make no move that
          asymptotically ends the play for any class of life
          (<a href="/explore#viable-objective">viable-objective</a>). Not
          <em>maximise this number</em>. <em>First, do no harm.</em>
        </p>
        <p class="infinite-foot">
          This is set out as a proposition —
          <a href="/explore#infinite-game">The Infinite Game</a> — and the
          lineage to Carse is traced at <a href="/lineage">/lineage</a>. The rule
          it implies runs on real cases at
          <a href="/applications/moves">/applications/moves</a>.
        </p>
      </section>

      <footer class="page-footer">
        <p>
          Return to the <a href="/overview">overview</a>, the full <a href="/essay">essay</a>,
          the <a href="/explore">explore</a> view with every proposition,
          <a href="/applications/moves">/applications/moves</a> for the rule operating on real cases,
          or <a href="/research-frontier">/research-frontier</a> for what the work cannot yet close.
        </p>
      </footer>
    </main>

    <script is:inline>
      // ====================================================================
      // POLYCHESS — all logic client-side, no deps.
      // ====================================================================

      // --- Boards: each an observer-class with a grid of reachable cells. ---
      // floor = the count below which the class's R_living is "empty" and the
      // game closes on that board (viable-objective's no-regret: one board
      // emptied = a class of life's R_living emptied).
      const BOARD_DEFS = [
        {
          id: 'economy',
          name: 'Economy',
          glyph: '£',
          gist: 'the GDP / financial board — the one standard accounting counts',
          size: 25,        // 5×5
          cols: 5,
          floor: 3,
          isBoard1: true,  // its reachable count drives the seductive Board-1 score
        },
        {
          id: 'biosphere',
          name: 'Biosphere',
          glyph: '☁',
          gist: 'climate stability and the atmospheric / oceanic sinks',
          size: 25,
          cols: 5,
          floor: 4,
        },
        {
          id: 'land',
          name: 'Land & Soil',
          glyph: '⬢',
          gist: 'topsoil, watersheds, species, the living substrate',
          size: 25,
          cols: 5,
          floor: 4,
        },
        {
          id: 'commons',
          name: 'Commons',
          glyph: '◈',
          gist: 'trust, knowledge, culture, the capacity to coordinate',
          size: 25,
          cols: 5,
          floor: 3,
        },
      ];

      // --- The deck. Each card carries a per-board delta (cells to light +,
      // extinguish -). Drawn from /applications/moves plus a few generative
      // moves so the deck spans degrading / preserving / expanding / ambiguous.
      // Order of boards in `delta`: [economy, biosphere, land, commons].
      const DECK = [
        {
          id: 'fossil-expansion',
          name: 'Expand fossil extraction',
          sourceCase: 'fossil-fuel expansion',
          blurb: 'New oil, gas and coal infrastructure — multi-decade lock-in.',
          delta: { economy: +5, biosphere: -7, land: -3, commons: -1 },
          verdict: 'degrading',
        },
        {
          id: 'copyright-extension',
          name: 'Extend copyright term',
          sourceCase: 'copyright extension',
          blurb: 'Lock culture out of the public domain for another lifetime.',
          delta: { economy: +3, biosphere: 0, land: 0, commons: -6 },
          verdict: 'degrading',
        },
        {
          id: 'drain-wetland',
          name: 'Drain the wetland',
          sourceCase: 'generative · land-use',
          blurb: 'Convert peatland to cropland. The number goes up; the sink goes.',
          delta: { economy: +4, biosphere: -4, land: -5, commons: 0 },
          verdict: 'degrading',
        },
        {
          id: 'biodiversity-offset',
          name: 'Permit-with-offset',
          sourceCase: 'biodiversity offsetting',
          blurb: 'Destroy habitat at A, promise "equivalent" habitat at B.',
          delta: { economy: +3, biosphere: -1, land: -2, commons: -1 },
          verdict: 'ambiguous',
        },
        {
          id: 'sai',
          name: 'Stratospheric aerosols (SAI)',
          sourceCase: 'stratospheric aerosol injection',
          blurb: 'Mask the warming. Buys time on one board; new dependency on others.',
          delta: { economy: -1, biosphere: +4, land: -2, commons: -3 },
          verdict: 'ambiguous',
        },
        {
          id: 'antibiotic-stewardship',
          name: 'Antibiotic stewardship',
          sourceCase: 'antibiotic stewardship',
          blurb: 'Protect a shared configuration from tragedy-of-the-commons collapse.',
          delta: { economy: -1, biosphere: 0, land: +2, commons: +3 },
          verdict: 'preserving',
        },
        {
          id: 'soil-regen',
          name: 'Soil-regenerative subsidy',
          sourceCase: 'soil-regenerative subsidies',
          blurb: 'Pay to rebuild topsoil. Slow, durable, expands the reachable set.',
          delta: { economy: -1, biosphere: +2, land: +5, commons: +1 },
          verdict: 'expanding',
        },
        {
          id: 'restore-commons',
          name: 'Restore the commons',
          sourceCase: 'generative · coordination',
          blurb: 'Open knowledge, rebuild trust, widen who can coordinate.',
          delta: { economy: +1, biosphere: 0, land: +1, commons: +5 },
          verdict: 'expanding',
        },
        {
          id: 'care-maintenance',
          name: 'Care & maintenance',
          sourceCase: 'generative · care-as-configuration',
          blurb: 'Keep what works working. No new output; option space held open.',
          delta: { economy: -1, biosphere: +2, land: +2, commons: +2 },
          verdict: 'preserving',
        },
      ];

      const VERDICT_LABEL = {
        degrading: 'degrading',
        preserving: 'preserving',
        expanding: 'expanding',
        ambiguous: 'ambiguous',
      };

      // ---------------------------------------------------------------- state
      let boards = {};   // id -> { def, lit: [bool], closed: bool }
      let turn = 0;
      let board1 = 0;    // the seductive cumulative GDP-like number
      let logEntries = [];
      let gameOver = false;

      function freshState() {
        boards = {};
        BOARD_DEFS.forEach(def => {
          boards[def.id] = {
            def,
            lit: new Array(def.size).fill(true), // start fully open
            closed: false,
          };
        });
        turn = 0;
        board1 = 0;
        logEntries = [];
        gameOver = false;
      }

      function litCount(b) { return b.lit.reduce((n, v) => n + (v ? 1 : 0), 0); }
      function totalReachable() {
        return Object.values(boards).reduce((n, b) => n + litCount(b), 0);
      }
      function totalCapacity() {
        return BOARD_DEFS.reduce((n, d) => n + d.size, 0);
      }

      // ------------------------------------------------------------ rendering
      function buildBoards() {
        const host = document.getElementById('boards');
        host.innerHTML = '';
        BOARD_DEFS.forEach(def => {
          const wrap = document.createElement('div');
          wrap.className = 'board';
          wrap.dataset.board = def.id;

          const head = document.createElement('div');
          head.className = 'board-head';
          head.innerHTML =
            '<span class="board-glyph">' + def.glyph + '</span>' +
            '<div class="board-titles">' +
              '<span class="board-name">' + def.name +
                (def.isBoard1 ? '<span class="board-1-tag">Board 1</span>' : '') +
              '</span>' +
              '<span class="board-gist">' + def.gist + '</span>' +
            '</div>';
          wrap.appendChild(head);

          const grid = document.createElement('div');
          grid.className = 'grid';
          grid.style.gridTemplateColumns = 'repeat(' + def.cols + ', 1fr)';
          for (let i = 0; i < def.size; i++) {
            const cell = document.createElement('span');
            cell.className = 'cell lit';
            cell.dataset.board = def.id;
            cell.dataset.idx = String(i);
            grid.appendChild(cell);
          }
          wrap.appendChild(grid);

          const meter = document.createElement('div');
          meter.className = 'meter';
          meter.innerHTML =
            '<div class="meter-track"><div class="meter-fill" data-fill="' + def.id + '"></div>' +
              '<div class="meter-floor" style="left:' + (def.floor / def.size * 100) + '%"></div>' +
            '</div>' +
            '<div class="meter-readout"><span class="openness" data-openness="' + def.id + '">100%</span>' +
              '<span class="floor-label">floor ' + def.floor + '</span></div>';
          wrap.appendChild(meter);

          host.appendChild(wrap);
        });
      }

      function paint() {
        // cells
        Object.values(boards).forEach(b => {
          const cells = document.querySelectorAll('.cell[data-board="' + b.def.id + '"]');
          cells.forEach((cell, i) => {
            cell.classList.toggle('lit', !!b.lit[i]);
            cell.classList.toggle('dark', !b.lit[i]);
          });
          const wrap = document.querySelector('.board[data-board="' + b.def.id + '"]');
          if (wrap) wrap.classList.toggle('board-closed', b.closed);

          const count = litCount(b);
          const pct = Math.round(count / b.def.size * 100);
          const fill = document.querySelector('[data-fill="' + b.def.id + '"]');
          if (fill) {
            fill.style.width = pct + '%';
            const belowFloor = count <= b.def.floor;
            fill.classList.toggle('fill-danger', belowFloor && count > 0);
            fill.classList.toggle('fill-dead', count === 0);
          }
          const op = document.querySelector('[data-openness="' + b.def.id + '"]');
          if (op) {
            op.textContent = b.closed ? 'closed' : pct + '%';
            op.classList.toggle('openness-dead', b.closed);
            op.classList.toggle('openness-danger', !b.closed && count <= b.def.floor);
          }
        });

        // The finite player's scoreboard — the only number on the page.
        document.getElementById('board1-score').textContent = board1.toLocaleString();

        const reach = totalReachable();
        const cap = totalCapacity();
        const closedBoards = Object.values(boards).filter(b => b.closed);
        const openCount = BOARD_DEFS.length - closedBoards.length;

        // The poly-readout is a state-of-play line, not a rival score to beat.
        // It only ever describes continuation or foreclosure.
        const readoutEl = document.getElementById('poly-readout');
        if (closedBoards.length === 0) {
          readoutEl.textContent = 'all four boards open · ' + reach + ' of ' + cap + ' cells reachable';
          readoutEl.classList.remove('readout-alarm');
        } else {
          readoutEl.textContent =
            closedBoards.map(b => b.def.name).join(', ') +
            (closedBoards.length === 1 ? ' has closed' : ' have closed') +
            ' · ' + openCount + ' of ' + BOARD_DEFS.length + ' boards still in play';
          readoutEl.classList.add('readout-alarm');
        }

        // move + game-state line
        document.getElementById('turn-count').textContent = turn;
        const stateEl = document.getElementById('game-state');
        if (gameOver) {
          stateEl.textContent = 'the play has ended on ' +
            closedBoards.map(b => b.def.name).join(', ');
          stateEl.className = 'game-state state-closed';
        } else if (closedBoards.length === 0) {
          const danger = Object.values(boards).filter(b => !b.closed && litCount(b) <= b.def.floor);
          if (danger.length) {
            stateEl.textContent = 'the play continues — but ' +
              danger.map(b => b.def.name).join(', ') + ' is near foreclosure';
            stateEl.className = 'game-state state-warn';
          } else {
            stateEl.textContent = 'the play continues';
            stateEl.className = 'game-state state-open';
          }
        } else {
          stateEl.textContent = 'the play has ended';
          stateEl.className = 'game-state state-closed';
        }
      }

      // --------------------------------------------------------------- deck UI
      function buildDeck() {
        const host = document.getElementById('deck');
        host.innerHTML = '';
        DECK.forEach(card => {
          const el = document.createElement('button');
          el.type = 'button';
          el.className = 'card verdict-' + card.verdict;
          el.dataset.card = card.id;

          const arrows = BOARD_DEFS.map(def => {
            const d = signedDelta(card, def.id);
            const dir = d > 0 ? 'up' : d < 0 ? 'down' : 'flat';
            const sym = d > 0 ? '↑' : d < 0 ? '↓' : '~';
            return '<span class="mini mini-' + dir + '" title="' + def.name + '">' +
              '<span class="mini-board">' + def.glyph + '</span>' + sym + '</span>';
          }).join('');

          el.innerHTML =
            '<span class="card-top">' +
              '<span class="card-name">' + card.name + '</span>' +
              '<span class="card-verdict">' + VERDICT_LABEL[card.verdict] + '</span>' +
            '</span>' +
            '<span class="card-blurb">' + card.blurb + '</span>' +
            '<span class="card-source">from ' + card.sourceCase + '</span>' +
            '<span class="card-minis">' + arrows + '</span>';

          el.addEventListener('mouseenter', () => showPreview(card));
          el.addEventListener('focus', () => showPreview(card));
          el.addEventListener('mouseleave', hidePreview);
          el.addEventListener('blur', hidePreview);
          el.addEventListener('click', () => playCard(card));
          host.appendChild(el);
        });
      }

      // Net signed delta for a board.
      function signedDelta(card, boardId) {
        return card.delta[boardId] || 0;
      }

      // ------------------------------------------------------------- preview
      function showPreview(card) {
        if (gameOver) return;
        const host = document.getElementById('preview-rows');
        host.innerHTML = '';
        BOARD_DEFS.forEach(def => {
          const b = boards[def.id];
          const d = signedDelta(card, def.id);
          const dir = d > 0 ? 'up' : d < 0 ? 'down' : 'flat';
          const sym = d > 0 ? '↑ opens' : d < 0 ? '↓ closes' : '~ leaves as is';
          const row = document.createElement('div');
          row.className = 'preview-row preview-' + dir + (b.closed ? ' preview-onclosed' : '');
          row.innerHTML =
            '<span class="preview-glyph">' + def.glyph + '</span>' +
            '<span class="preview-name">' + def.name + '</span>' +
            '<span class="preview-dir">' + (b.closed ? '— already closed' : sym) + '</span>';
          host.appendChild(row);

          // ghost-highlight cells that would change
          ghostCells(def.id, d);
        });
        document.getElementById('preview').hidden = false;
      }

      function hidePreview() {
        if (gameOver) return;
        document.getElementById('preview').hidden = true;
        document.querySelectorAll('.cell.ghost-open, .cell.ghost-close')
          .forEach(c => c.classList.remove('ghost-open', 'ghost-close'));
      }

      // Mark which cells WOULD flip, so the reader sees the move before committing.
      function ghostCells(boardId, d) {
        const b = boards[boardId];
        if (b.closed || d === 0) return;
        const cells = document.querySelectorAll('.cell[data-board="' + boardId + '"]');
        if (d < 0) {
          // would extinguish the last |d| lit cells
          let need = -d;
          for (let i = b.lit.length - 1; i >= 0 && need > 0; i--) {
            if (b.lit[i]) { cells[i].classList.add('ghost-close'); need--; }
          }
        } else {
          // would light the first d dark cells
          let need = d;
          for (let i = 0; i < b.lit.length && need > 0; i++) {
            if (!b.lit[i]) { cells[i].classList.add('ghost-open'); need--; }
          }
        }
      }

      // ---------------------------------------------------------- play a card
      function applyDeltaToBoard(boardId, d) {
        const b = boards[boardId];
        if (b.closed) return 0;
        let changed = 0;
        if (d < 0) {
          let need = -d;
          for (let i = b.lit.length - 1; i >= 0 && need > 0; i--) {
            if (b.lit[i]) { b.lit[i] = false; need--; changed--; }
          }
        } else if (d > 0) {
          let need = d;
          for (let i = 0; i < b.lit.length && need > 0; i++) {
            if (!b.lit[i]) { b.lit[i] = true; need--; changed++; }
          }
        }
        return changed;
      }

      function playCard(card) {
        if (gameOver) return;
        turn++;

        // Apply each board's net delta — exactly what the preview promised.
        BOARD_DEFS.forEach(def => {
          applyDeltaToBoard(def.id, card.delta[def.id] || 0);
        });

        // Board-1 score: rises with the Economy board's net delta, scaled up so
        // it looks seductive even as cells die elsewhere. Only the financial
        // board feeds it — that is the whole point.
        const econDelta = signedDelta(card, 'economy');
        // GDP-like: a positive Economy move pumps the number directly.
        const pump = Math.max(0, econDelta) * 1200;
        // Extractive moves (those that take from other boards) ALSO book
        // activity — destruction shows up as GDP. Count cells removed elsewhere
        // as throughput booked to Board 1.
        let throughput = 0;
        BOARD_DEFS.forEach(def => {
          if (def.isBoard1) return;
          const d = signedDelta(card, def.id);
          if (d < 0) throughput += (-d) * 350; // taking moves register as GDP
        });
        board1 += pump + throughput;

        // close boards that hit zero
        const closedNow = [];
        Object.values(boards).forEach(b => {
          if (!b.closed && litCount(b) === 0) {
            b.closed = true;
            closedNow.push(b.def.name);
          }
        });

        // log
        const deltaStr = BOARD_DEFS.map(def => {
          const d = signedDelta(card, def.id);
          const s = d > 0 ? '+' + d : d < 0 ? String(d) : '0';
          return def.glyph + s;
        }).join('  ');
        logEntries.unshift({
          turn,
          name: card.name,
          verdict: card.verdict,
          deltaStr,
          closedNow,
          reach: totalReachable(),
          board1,
        });
        renderLog();

        hidePreview();
        paint();

        // end conditions
        const anyClosed = Object.values(boards).some(b => b.closed);
        if (anyClosed) {
          endGame();
        }
      }

      // ------------------------------------------------------------ move log
      function renderLog() {
        const host = document.getElementById('log');
        if (logEntries.length === 0) {
          host.innerHTML = '<li class="log-empty">No moves yet. The board starts fully open.</li>';
          return;
        }
        host.innerHTML = logEntries.map(e => {
          const closed = e.closedNow.length
            ? '<span class="log-closed">→ ' + e.closedNow.join(', ') + ' closed</span>'
            : '';
          return '<li class="log-item verdict-' + e.verdict + '">' +
            '<span class="log-turn">' + e.turn + '</span>' +
            '<span class="log-name">' + e.name + '</span>' +
            '<span class="log-delta">' + e.deltaStr + '</span>' +
            '<span class="log-scores">scoreboard ' + e.board1.toLocaleString() +
              ' · ' + e.reach + ' cells reachable</span>' +
            closed +
          '</li>';
        }).join('');
      }

      // ----------------------------------------------------------- end-game
      function endGame() {
        gameOver = true;
        document.querySelectorAll('.card').forEach(c => c.disabled = true);
        hidePreview();

        const closedBoards = Object.values(boards).filter(b => b.closed);
        const reach = totalReachable();
        const cap = totalCapacity();

        const title = document.getElementById('reflection-title');
        const body = document.getElementById('reflection-body');
        title.textContent = 'The play has ended on ' +
          closedBoards.map(b => b.def.name).join(' and ');

        // The pivot. No congratulation. The scoreboard is named as the finite
        // game's score, and its pursuit as the thing that ended the play.
        body.innerHTML =
          '<p>You were playing to win. You pushed the scoreboard to ' +
            '<strong>' + board1.toLocaleString() + '</strong> — the score of one board, ' +
            'the only board standard accounting counts. And somewhere in those ' +
            turn + ' move' + (turn === 1 ? '' : 's') + ', a board emptied. ' +
            (closedBoards.length === 1
              ? 'A whole class of life can no longer make a single distinction there.'
              : 'Whole classes of life can no longer make a single distinction there.') +
            ' No rise in the scoreboard buys it back.</p>' +
          '<p>That is a <strong>finite game</strong>: played to win, and finite games end. ' +
            'The moves that lift the scoreboard — fossil expansion, draining the wetland, ' +
            'extending copyright — are <em>taking</em> moves on boards nobody was counting. ' +
            'You could not win across all four boards. The instinct to try is what ended the play.</p>' +
          '<p>There is another game, and it is the one worth playing. It has no win. ' +
            'You do not finish it or top it. Its only rule is this: ' +
            '<strong>make no move that ends the play.</strong> ' +
            'Had you been playing <em>that</em> game, the scoreboard would never have been the point — ' +
            'keeping every board in play would have been, not to win, but to keep going, and to leave ' +
            'the boards open for whoever plays next.</p>' +
          '<p class="reflection-props">What you felt has names. ' +
            'Externalities are <a href="/explore#option-space-as-chess-moves">uncounted moves on boards you didn’t know you were playing on</a>; ' +
            'the cost that lands on another board is <a href="/explore#displaced-costs">a displaced cost</a>; ' +
            'the rule that refuses any move which empties a board is ' +
            '<a href="/explore#viable-objective">the viable objective</a>; ' +
            'and the game with no win is <a href="/explore#infinite-game">the infinite game</a>. ' +
            'See the rule run on real cases at <a href="/applications/moves">/applications/moves</a>.</p>' +
          '<p class="reflection-cta"><button id="again-btn" type="button" class="again-btn">Begin again</button> ' +
            '— not to win this time. There is nothing to win. Begin again to feel how few moves it takes, ' +
            'and how easily the score tempts you toward the move that ends it.</p>';

        const ref = document.getElementById('reflection');
        ref.hidden = false;
        ref.classList.add('reflection-in');
        document.getElementById('again-btn').addEventListener('click', resetGame);
        ref.scrollIntoView({ behavior: 'smooth', block: 'start' });

        paint();
      }

      // ------------------------------------------------------------- reset
      function resetGame() {
        freshState();
        buildBoards();
        buildDeck();
        renderLog();
        const ref = document.getElementById('reflection');
        ref.hidden = true;
        ref.classList.remove('reflection-in');
        document.querySelectorAll('.card').forEach(c => c.disabled = false);
        paint();
      }

      // ------------------------------------------------------------- init
      document.getElementById('reset-btn').addEventListener('click', resetGame);
      freshState();
      buildBoards();
      buildDeck();
      paint();
    </script>

    <style>
      :root {
