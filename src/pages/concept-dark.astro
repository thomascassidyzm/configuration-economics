---
// Redirect: /concept-dark was merged into /format.
// Preserve dark preference for anyone who bookmarked this route specifically.
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Redirecting...</title>
  <script is:inline>
    try { localStorage.setItem('format-theme', 'dark'); } catch (e) {}
    window.location.replace('/format');
  </script>
  <meta http-equiv="refresh" content="0; url=/format">
</head>
<body>
  <p>Redirecting to <a href="/format">/format</a>…</p>
</body>
</html>
